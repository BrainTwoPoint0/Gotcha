// prisma/schema.prisma

generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
  engineType    = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ============================================
// ORGANIZATION & AUTH
// ============================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Element archiving
  archivedElementIds String[] @default([])

  // Relations
  members      OrganizationMember[]
  projects     Project[]
  subscription Subscription?
  invitations  Invitation[]
}

model OrganizationMember {
  id             String     @id @default(cuid())
  organizationId String
  userId         String
  role           MemberRole @default(MEMBER)
  createdAt      DateTime   @default(now())

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Profile fields (onboarding)
  companySize String? // "solo" | "2-10" | "11-50" | "50+"
  role        String? // "founder" | "engineer" | "pm" | "designer" | "other"
  industry    String? // "saas" | "ecommerce" | "education" | "healthcare" | "agency" | "other"
  useCase     String? // "user-feedback" | "feature-validation" | "bug-reports" | "nps" | "polls" | "other"
  onboardedAt DateTime? // Set when user completes or skips onboarding

  // Relations
  memberships     OrganizationMember[]
  sentInvitations Invitation[]

  @@index([email])
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  email          String
  role           MemberRole   @default(MEMBER)
  token          String       @unique
  status         InviteStatus @default(PENDING)
  invitedById    String
  createdAt      DateTime     @default(now())
  expiresAt      DateTime

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([token])
  @@index([email])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

// ============================================
// PROJECTS & API KEYS
// ============================================

model Project {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  slug           String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Settings
  settings Json @default("{}")

  // Notify-back abuse cap: per-project monthly counter on shipped emails.
  // Hard cap protects Gotcha's sending reputation from a malicious or
  // misconfigured customer seeding many submitter emails. Resets on rollover
  // when the PATCH route observes the calendar month changed.
  notifiesSentThisMonth Int       @default(0)
  notifiesResetAt       DateTime?

  // Per-project salt for roadmap upvote voter hashes. Lazy-generated on
  // first vote (cuid()), immutable after. Salting per-project means the
  // same browser voting on two different customers' roadmaps produces two
  // different voterHash values — cross-project voter correlation is
  // cryptographically infeasible.
  votingSalt String?

  // Relations
  organization          Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  apiKeys               ApiKey[]
  elements              Element[]
  responses             Response[]
  experiments           Experiment[]
  metadataFields        MetadataField[]
  webhooks              Webhook[]
  bugTickets            BugTicket[]
  submitterSuppressions SubmitterSuppression[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model ApiKey {
  id             String    @id @default(cuid())
  projectId      String
  name           String // e.g., "Production", "Development"
  key            String    @unique // gtch_live_xxx or gtch_test_xxx
  keyHash        String    @unique // For secure lookup
  allowedDomains String[] // ["*.myapp.com", "localhost:*"] for origin validation
  lastUsedAt     DateTime?
  createdAt      DateTime  @default(now())
  revokedAt      DateTime?

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ============================================
// ELEMENTS & FEEDBACK
// ============================================

model Element {
  id          String   @id @default(cuid())
  projectId   String
  elementId   String // Developer-provided identifier
  name        String? // Optional friendly name
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  responses Response[]

  @@unique([projectId, elementId])
  @@index([projectId])
}

model Response {
  id           String  @id @default(cuid())
  projectId    String
  elementId    String? // FK to Element
  elementIdRaw String // Original elementId string (for unregistered elements)

  // Response data
  mode    ResponseMode
  content String? // Text feedback or feature request description
  title   String? // For feature requests
  rating  Int? // 1-5 or 1-10
  vote    VoteType? // For vote mode

  // Poll specific
  pollOptions  Json? // Array of options that were presented
  pollSelected Json? // Array of selected option(s) - indexes or values

  // A/B specific
  experimentId String?
  variant      String?

  // User data (flexible JSON for arbitrary metadata)
  endUserId   String? // The ID passed by developer
  endUserMeta Json    @default("{}")

  // Context
  url         String? // Page URL where feedback was given
  userAgent   String?
  contextMeta Json? // Extended context (viewport, errors, etc.)

  // Idempotency
  idempotencyKey String?

  // Plan gating — true when response was collected beyond the monthly free limit
  gated Boolean @default(false)

  // Review status
  status     ResponseStatus @default(NEW)
  tags       String[]       @default([])
  reviewedAt DateTime?
  reviewedBy String?

  // Loop lifecycle — see ResponseStatus enum. statusUpdatedAt/By are stamped
  // on every transition; shippedAt is set only on the transition to SHIPPED.
  statusUpdatedAt DateTime?
  statusUpdatedBy String?
  shippedAt       DateTime?

  // Notify-back to the submitter. submitterEmail is captured via the SDK
  // `userEmail` prop (optional — empty when the host app doesn't pass it).
  // notifiedAt is the idempotency guard: one notify-back email per response,
  // stamped only after Resend accepts the send.
  submitterEmail String?
  notifiedAt     DateTime?
  shippedNote    String?

  // Materialised public roadmap upvote counter. Kept in sync with RoadmapVote
  // row count inside the vote-toggle transaction so the public page can read
  // it without a COUNT(*) scan on every render.
  //
  // CONTRACT: this column must ONLY be mutated by the /api/public/roadmap/
  // [slug]/vote route (inside its $transaction), which couples the increment
  // with a matching RoadmapVote insert. Any other write path will drift the
  // counter from row-count and break the public roadmap's sort order.
  upvoteCount Int @default(0)

  // Timestamps
  createdAt DateTime @default(now())

  // Bug flagging
  isBug     Boolean    @default(false)
  bugTicket BugTicket?

  // Relations
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  element      Element?      @relation(fields: [elementId], references: [id], onDelete: SetNull)
  experiment   Experiment?   @relation(fields: [experimentId], references: [id], onDelete: SetNull)
  roadmapVotes RoadmapVote[]
  // Roadmap path lives in a partial index declared in the
  // 20260415000000_response_lifecycle migration:
  //   CREATE INDEX ... ON "Response"("projectId", "createdAt" DESC)
  //     WHERE status IN ('PLANNED','IN_PROGRESS','SHIPPED');
  // Smaller than a full composite, sorted-scan-friendly for the IN-list
  // predicate the public roadmap query uses. Prisma doesn't model partial
  // indexes natively — future migrations must preserve it manually.

  // Note: Unique constraint on [projectId, elementIdRaw, endUserId] not used
  // because existing data has duplicates. Edit checks handled in application layer.
  @@index([projectId])
  @@index([elementId])
  @@index([projectId, elementIdRaw])
  @@index([experimentId])
  @@index([createdAt])
  @@index([endUserId])
  @@index([idempotencyKey])
}

enum ResponseMode {
  FEEDBACK
  VOTE
  POLL
  FEATURE_REQUEST
  AB
  NPS
}

// Legacy triage values (NEW/REVIEWED/ADDRESSED/ARCHIVED) are preserved so
// existing rows remain valid. The lifecycle values below form the Canny-style
// loop that's surfaced on the public roadmap. UI aliases REVIEWED→UNDER_REVIEW
// in the label map; ADDRESSED is legacy and can be bulk-migrated to SHIPPED
// from settings if the admin wants cleanup.
enum ResponseStatus {
  NEW
  REVIEWED
  ADDRESSED
  ARCHIVED
  UNDER_REVIEW
  PLANNED
  IN_PROGRESS
  SHIPPED
  DECLINED
}

enum VoteType {
  UP
  DOWN
}

// ============================================
// A/B EXPERIMENTS
// ============================================

model Experiment {
  id           String           @id @default(cuid())
  projectId    String
  experimentId String // Developer-provided identifier
  name         String
  description  String?
  variants     Json // Array of variant names
  status       ExperimentStatus @default(DRAFT)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  startedAt    DateTime?
  endedAt      DateTime?

  // Relations
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  responses Response[]

  @@unique([projectId, experimentId])
  @@index([projectId])
}

enum ExperimentStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
}

// ============================================
// METADATA FIELDS
// ============================================

model MetadataField {
  id          String   @id @default(cuid())
  projectId   String
  fieldKey    String // e.g., "age", "location", "plan"
  displayName String? // e.g., "Age Group", "Country"
  fieldType   String   @default("string") // "string" | "number" | "boolean"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, fieldKey])
  @@index([projectId])
}

// ============================================
// BILLING
// ============================================

model Subscription {
  id                String    @id @default(cuid())
  organizationId    String    @unique
  stripeCustomerId  String?
  stripePriceId     String?
  stripeSubId       String?
  plan              Plan      @default(FREE)
  status            SubStatus @default(ACTIVE)
  cancelAtPeriodEnd Boolean   @default(false)
  currentPeriodEnd  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Usage tracking
  responsesThisMonth Int       @default(0)
  responsesResetAt   DateTime?

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
}

// Only FREE and PRO are actively used. STARTER and ENTERPRISE are retained
// to avoid a migration that would break existing rows referencing them.
enum Plan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum SubStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

// ============================================
// WEBHOOKS
// ============================================

model Webhook {
  id              String    @id @default(cuid())
  projectId       String
  type            String    @default("custom") // "custom" | "slack" | "discord"
  url             String
  secret          String?
  events          String[] // e.g. ["response.created"]
  active          Boolean   @default(true)
  description     String?
  lastTriggeredAt DateTime?
  lastStatusCode  Int?
  failureCount    Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  logs    WebhookLog[]

  @@index([projectId])
}

model WebhookLog {
  id         String   @id @default(cuid())
  webhookId  String
  event      String
  payload    Json
  statusCode Int?
  responseMs Int?
  error      String?
  success    Boolean
  createdAt  DateTime @default(now())

  // Relations
  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([createdAt])
}

// ============================================
// BUG TICKETS
// ============================================

model BugTicket {
  id         String @id @default(cuid())
  projectId  String
  responseId String @unique

  // Auto-populated from response context
  title         String
  description   String
  elementId     String
  pageUrl       String?
  userAgent     String?
  endUserMeta   Json?
  endUserId     String?
  reporterEmail String?
  reporterName  String?

  // Ticket management
  status   BugStatus   @default(OPEN)
  priority BugPriority @default(MEDIUM)

  // Resolution
  resolvedAt     DateTime?
  resolvedBy     String?
  resolutionNote String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  response Response  @relation(fields: [responseId], references: [id], onDelete: Cascade)
  notes    BugNote[]

  @@index([projectId, status])
  @@index([projectId, createdAt])
}

model BugNote {
  id          String   @id @default(cuid())
  bugTicketId String
  authorEmail String
  authorName  String?
  content     String
  isExternal  Boolean  @default(false)
  createdAt   DateTime @default(now())

  // Relations
  bugTicket BugTicket @relation(fields: [bugTicketId], references: [id], onDelete: Cascade)

  @@index([bugTicketId, createdAt])
}

enum BugStatus {
  OPEN
  INVESTIGATING
  FIXING
  RESOLVED
  CLOSED
  WONT_FIX
}

enum BugPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ============================================
// ROADMAP UPVOTES
// ============================================

// Anonymous upvotes on the public roadmap. Dedup is enforced by the
// (responseId, voterHash) unique constraint — the same primitive also
// authorises toggle-off (the returning browser hashes identically and
// deletes its own row).
//
// voterHash = sha256(project.votingSalt | ip | ua-normalised). Per-project
// salting makes cross-project voter correlation infeasible.
model RoadmapVote {
  id         String   @id @default(cuid())
  responseId String
  voterHash  String
  createdAt  DateTime @default(now())

  response Response @relation(fields: [responseId], references: [id], onDelete: Cascade)

  // The unique composite's leading column serves any responseId-only
  // lookup (FK cascade, count-by-response), so a standalone
  // @@index([responseId]) would be strictly redundant — same selectivity,
  // extra write amplification. Leaving it off intentionally.
  @@unique([responseId, voterHash])
}

// ============================================
// NOTIFY-BACK SUPPRESSION
// ============================================

// Per-project email suppression. Populated when a recipient clicks the
// signed-token unsubscribe link in a shipped-notification email. The PATCH
// status route must check this table before sending a notify-back. Email is
// stored verbatim (not hashed) because we need exact-match lookup; the
// email is already public PII the customer's user supplied themselves.
model SubmitterSuppression {
  id        String   @id @default(cuid())
  projectId String
  email     String
  createdAt DateTime @default(now())

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, email])
  @@index([projectId])
}
